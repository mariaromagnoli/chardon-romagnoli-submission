FAP_PATTERN <- "[A-Z][0-9][A-Z][0-9A-Z][0-9]"
# Lines to discard from PDF text
is_artefact <- function(x) { grepl(paste0("legifrance\\.gouv\\.fr", "|^[0-9]+ of [0-9]+", "|Cacher le tableau", "|Afficher le tableau", "|^Fait . Paris"), x)}
### STEP 2: FUNCTION: EXTRACT FAP-PCS MAPPING (from Excel) ---------------------
parse_fap_mapping <- function(xls_path) {
raw <- read_excel(xls_path, sheet = 1, col_names = FALSE)
names(raw) <- c("fap_code", "fap_label", "pcs_code", "pcs_label", "rome_code", "rome_qual", "rome_label")
raw |> fill(fap_code, fap_label, .direction = "down") |> # Fill fap_code and fap_label down through multi-PCS rows
filter(grepl(paste0("^", FAP_PATTERN, "$"), fap_code)) |> # Keep only 5-char FAP codes (filters out category headers like "A", "A0Z")
filter(!is.na(pcs_code)) |>
mutate(pcs_code = toupper(as.character(pcs_code))) |>
select(fap_code, fap_label, pcs_code, pcs_label) |>
distinct(fap_code, pcs_code, .keep_all = TRUE)}
### STEP 3: FUNCTION: EXTRACT 2021 LIST ----------------------------------------
# FAP code to the right of each line
parse_list_2021 <- function(pdf_path) {
pages <- pdf_text(pdf_path)
all_text <- paste(pages, collapse = "\n")
lines <- str_split(all_text, "\n")[[1]]
result  <- list()
current_region <- NA_character_
row_counter <- 0L
pending_label  <- ""
for (i in seq_along(lines)) {
line  <- N(lines[i])
line_trimmed <- str_trim(line)
if (nchar(line_trimmed) == 0) { pending_label <- ""; next }
if (is_artefact(line_trimmed)) next
# Region header
if (line_trimmed %in% METRO_REGIONS || line_trimmed %in% names(REGION_ALIASES)) {
current_region <- canonicalise_region(line_trimmed)
row_counter <- 0L
pending_label <- ""
next}
# Skip table column headers
if (str_detect(line_trimmed, paste0("^(Code|Familles|FAP|R.gions|ANNEXE|LISTE|Arr.t|Article|", "Le secr|d.l.gu|cod.veloppement|l.immigration|publi.|Cacher|Afficher|Annexe)"))) {
pending_label <- ""
next}
# FAP code at the END of the line
fap_match <- str_extract(line_trimmed, paste0(FAP_PATTERN, "\\s*$"))
if (!is.na(fap_match) && !is.na(current_region)) {
fap_code <- str_trim(fap_match)
label_this <- str_trim(str_remove(line_trimmed, paste0(FAP_PATTERN, "\\s*$")))
full_label <- str_trim(paste(pending_label, label_this))
# Check for a label continuation on the very next line
if (i < length(lines)) {
next_line <- str_trim(N(lines[i + 1]))
next_has_fap   <- !is.na(str_extract(next_line, paste0(FAP_PATTERN, "\\s*$")))
next_is_region <- next_line %in% METRO_REGIONS
next_is_header <- str_detect(next_line, "^(Code|Familles|FAP|legifrance|^[0-9]+ of)")
if (!next_has_fap && !next_is_region && !next_is_header &&
nchar(next_line) > 0) {
full_label <- str_trim(paste(full_label, next_line))}}
row_counter <- row_counter + 1L
result[[length(result) + 1]] <- tibble(
fap_code      = fap_code,
job           = if (nchar(full_label) > 0) full_label else NA_character_,
region        = current_region,
row_in_region = row_counter)
pending_label <- ""}
else {
# start of a multi-line label
pending_label <- line_trimmed}}
bind_rows(result)}
### STEP 4: FUNCTION: APPLY 2024 AMENDMENT -------------------------------
apply_2024_amendment <- function(list_2021) {
# Report row counts per region
region_sizes <- list_2021 |> count(region, name = "n_rows") |> arrange(region)
cat("  2021 list rows per region:\n")
print(region_sizes)
# Mark removals
removed_keys <- imap_dfr(REMOVALS_2024, function(rows, region) {
region_data <- list_2021 |> filter(region == !!region)
if (nrow(region_data) == 0) {
warning("Region '", region, "' not found in 2021 list for 2024 removals")
return(tibble())}
valid_rows <- rows[rows <= nrow(region_data)]
if (length(valid_rows) < length(rows)) {
warning("  Row position(s) ", paste(rows[rows > nrow(region_data)], collapse=", "), " exceed table size (", nrow(region_data), ") for '", region, "'", " — those positions are skipped")
}
if (length(valid_rows) == 0) return(tibble())
cat("  Removing from", region, ": rows", paste(valid_rows, collapse=", "), "→ FAP codes:", paste(region_data$fap_code[valid_rows], collapse=", "), "\n")
region_data[valid_rows, c("fap_code", "region")]})
list_2021_marked <- list_2021 |> left_join(removed_keys |> mutate(delisted_2024 = 1L), by = c("fap_code", "region")) |>
mutate(delisted_2024 = replace_na(delisted_2024, 0L), listing_year  = 2021L)
# Additions, 4 codes × 13 regions, only where not already listed
additions <- expand_grid(fap_code = ADDITIONS_2024_CODES, region= METRO_REGIONS) |>
anti_join(list_2021 |> select(fap_code, region), by = c("fap_code", "region")) |>
mutate(job = NA_character_, row_in_region = NA_integer_, listing_year  = 2024L, delisted_2024 = 0L)
cat("  New entries added by 2024 amendment:", nrow(additions), "\n")
bind_rows(list_2021_marked, additions)}
### STEP 5: FUNCTION: EXTRACT 2025 LIST ---------------------------------------
parse_list_2025 <- function(pdf_path) {
pages <- pdf_text(pdf_path)
all_text <- paste(pages, collapse = "\n")
lines <- str_split(all_text, "\n")[[1]]
result <- list()
current_region <- NA_character_
pending_fap <- NA_character_
in_annex2  <- FALSE
for (i in seq_along(lines)) {
line         <- N(lines[i])
line_trimmed <- str_trim(line)
if (nchar(line_trimmed) == 0) { pending_fap <- NA_character_; next }
if (is_artefact(line_trimmed)) next
# Stop processing once Annex II is reached
if (str_detect(line_trimmed, "ANNEXE\\s*II|ANNEXE\\s*2")) { in_annex2 <- TRUE }
if (in_annex2) next
if (line_trimmed %in% METRO_REGIONS || line_trimmed %in% names(REGION_ALIASES)) {
current_region <- canonicalise_region(line_trimmed)
pending_fap    <- NA_character_
next}
if (str_detect(line_trimmed,paste0("^(Code|Familles|FAP|R.gions|ANNEXE|LISTE|Arr.t|Article|","Le secr|d.l.gu|cod.veloppement|publi.|Cacher|Afficher|Annexe)"))) next
# FAP code at the START of the trimmed line
fap_at_start <- str_extract(line_trimmed, paste0("^", FAP_PATTERN, "\\b"))
if (!is.na(fap_at_start) && !is.na(current_region)) {
label_after <- str_trim(str_remove(line_trimmed, paste0("^", FAP_PATTERN, "\\s*")))
result[[length(result) + 1]] <- tibble(
fap_code = fap_at_start,
job      = if (nchar(label_after) > 0) label_after else NA_character_,
region   = current_region)
pending_fap <- if (nchar(label_after) == 0) fap_at_start else NA_character_
} else if (!is.na(pending_fap) && !is.na(current_region)) {
# Label continuation for the previous code-only line
idx <- length(result)
if (idx > 0 && result[[idx]]$fap_code == pending_fap) {
existing <- replace_na(result[[idx]]$job, "")
result[[idx]]$job <- str_trim(paste(existing, line_trimmed))}
pending_fap <- NA_character_}}
bind_rows(result)
}
### STEP 6: FUNCTION: EXTRACT 2008 LIST ---------------------------------------
# Plain text, old regions
parse_list_2008 <- function(pdf_path) {
cat("Parsing 2008 list...\n")
pages    <- pdf_text(pdf_path)
all_text <- paste(pages, collapse = "\n")
lines    <- str_split(all_text, "\n")[[1]]
result         <- list()
current_region <- NA_character_
pending_job    <- ""
for (line in lines) {
line_trimmed <- N(str_trim(line))
if (nchar(line_trimmed) == 0) next
if (is_artefact(line_trimmed)) next
if (str_detect(line_trimmed, paste0("^(ANNEXE|LISTE|R.gion|Article|Le secr|cod.veloppement|", "l.immigration|d.l.gu|Arr.t|publi.|Cacher|Afficher|Annexe)"))) next
if (line_trimmed %in% OLD_REGIONS) {
if (nchar(pending_job) > 0) {
warning("Incomplete job title dropped at region boundary: '", pending_job, "'")
pending_job <- ""}
current_region <- line_trimmed
next}
if (is.na(current_region)) next
combined <- str_trim(paste(pending_job, line_trimmed))
if (str_ends(combined, fixed("."))) {
job_title <- str_trim(str_remove(combined, "\\.$"))
result[[length(result) + 1]] <- tibble(job_title_2008 = job_title, old_region  = current_region)
pending_job <- ""
} else {
pending_job <- combined}}
raw <- bind_rows(result) |> mutate(job_title_2008 = N(job_title_2008))
raw |> left_join(REGION_MAP_2008, by = c("old_region" = "old")) |>
rename(region = new) |>
left_join(JOB_FAP_2008, by = "job_title_2008") |>
mutate(listing_year = 2008L) |>
select(job_title_2008, fap_code, region, listing_year)}
### STEP 7: PARSE ----------------------------------------
fap_map <- parse_fap_mapping("correspondance.xls")
list_2021 <- parse_list_2021("2021list.pdf")
list_2021_amended <- apply_2024_amendment(list_2021)
list_2025  <- parse_list_2025("2025list.pdf")
list_2008 <- parse_list_2008("2008list.pdf")
cat("\nRow counts:\n")
cat("  fap_map:", nrow(fap_map), "unique (fap_code, pcs_code) pairs\n")
cat("  list_2021:", nrow(list_2021), "rows\n")
cat("  list_2021_amended:", nrow(list_2021_amended), "rows\n")
cat("  list_2025:", nrow(list_2025), "rows\n")
cat("  list_2008:", nrow(list_2008), "rows\n")
cat("\n2025 list rows per region:\n")
print(list_2025 |> count(region))
### STEP 8: BUILD DATASET -----------------------------------------------------
all_listings <- bind_rows( list_2008 |> filter(!is.na(fap_code)) |> select(fap_code, region, listing_year),
list_2021_amended |> select(fap_code, region, listing_year))
first_listings <- all_listings |> group_by(fap_code, region) |> summarise(listing_year = min(listing_year), .groups = "drop")
# delisted_2021: in 2008 but not carried into the 2021 list
in_2008 <- list_2008 |> filter(!is.na(fap_code)) |> distinct(fap_code, region)
in_2021 <- list_2021 |> distinct(fap_code, region)
delisted_2021_flags <- in_2008 |> anti_join(in_2021, by = c("fap_code", "region")) |> mutate(delisted_2021 = 1L)
# delisted_2024: removed by the March 2024 amendment
delisted_2024_flags <- list_2021_amended |> filter(delisted_2024 == 1L) |> distinct(fap_code, region) |> mutate(delisted_2024 = 1L)
# delisted_2025: in 2021/2024 but not in 2025
active_pre_2025 <- list_2021_amended |> filter(delisted_2024 == 0L) |> distinct(fap_code, region)
in_2025 <- list_2025 |> distinct(fap_code, region)
delisted_2025_flags <- active_pre_2025 |> anti_join(in_2025, by = c("fap_code", "region")) |> mutate(delisted_2025 = 1L)
# 2025 entries not seen in any prior list
new_in_2025 <- in_2025 |> anti_join(active_pre_2025, by = c("fap_code", "region")) |>
anti_join(list_2008 |> filter(!is.na(fap_code)) |> select(fap_code, region), by = c("fap_code", "region")) |>
mutate(listing_year = 2025L)
first_listings <- bind_rows(first_listings, new_in_2025) |>
group_by(fap_code, region) |>
summarise(listing_year = min(listing_year), .groups = "drop")
# relisted_2025: was previously delisted (2021 or 2024) and reappears in 2025
relisted_2025_flags <- bind_rows(delisted_2021_flags |> select(fap_code, region),
delisted_2024_flags |> select(fap_code, region)) |>
distinct(fap_code, region) |>
semi_join(in_2025, by = c("fap_code", "region")) |>
mutate(relisted_2025 = 1L)
master <- first_listings |>
left_join(delisted_2021_flags, by = c("fap_code", "region")) |>
left_join(delisted_2024_flags, by = c("fap_code", "region")) |>
left_join(delisted_2025_flags, by = c("fap_code", "region")) |>
left_join(relisted_2025_flags, by = c("fap_code", "region")) |>
mutate(
delisted_2021      = replace_na(delisted_2021, 0L),
delisted_2024      = replace_na(delisted_2024, 0L),
delisted_2025      = replace_na(delisted_2025, 0L),
relisted_2025      = replace_na(relisted_2025, 0L),
treatment          = 1L,
treatment_2008     = if_else(listing_year == 2008L, 1L, 0L),
treatment_2021     = if_else(listing_year == 2021L, 1L, 0L),
treatment_2024     = if_else(listing_year == 2024L, 1L, 0L),
treatment_2025     = if_else(listing_year == 2025L, 1L, 0L),
treatment_2025_all = if_else(treatment_2025 == 1L | relisted_2025 == 1L, 1L, 0L))
# Attach source job labels
job_labels_2021 <- list_2021  |> filter(!is.na(job)) |> distinct(fap_code, region, job)
job_labels_2025 <- list_2025  |> filter(!is.na(job)) |> distinct(fap_code, region, job)
job_labels_2008 <- list_2008  |> filter(!is.na(fap_code)) |> rename(job = job_title_2008) |> distinct(fap_code, region, job)
job_labels <- bind_rows(job_labels_2021, job_labels_2025, job_labels_2008) |> distinct(fap_code, region, .keep_all = TRUE)
master <- master |> left_join(job_labels, by = c("fap_code", "region"))
### STEP 9: JOIN PCS -----------------------------------------------------
#although this is already done in CASD.
final <- master |> left_join(fap_map, by = "fap_code", relationship = "many-to-many") |>
select(listing_year, region, job, fap_code, fap_label, pcs_code, pcs_label,
treatment, treatment_2008, treatment_2021, treatment_2024, treatment_2025, treatment_2025_all,
relisted_2025, delisted_2021, delisted_2024, delisted_2025)
write_csv(final, "/Users/maria/Desktop/chardon-romagnoli-submission/01 Extraction/shortage_list.csv")
### STEP 10: SANITY -----------------------------------------------------
# Exactly one treatment year flag per row in master
treatment_check <- master |>
mutate(sum_treat = treatment_2008 + treatment_2021 + treatment_2024 + treatment_2025) |>
filter(sum_treat != 1L)
if (nrow(treatment_check) == 0) {
cat("Good \n")} else {
cat("There are rows with inconsistent counts:", nrow(treatment_check), "\n")
print(treatment_check)}
# Column NA summary
final |> summarise(across(everything(), \(x) sum(is.na(x)))) |>
pivot_longer(everything(), names_to = "column", values_to = "n_na") |>
print(n = Inf)
# Rows by listing_year
cat("\nRows by listing_year (final dataset after PCS join):\n")
print(count(final, listing_year))
cat("\nUnique (fap_code, region) pairs in master:", nrow(master), "\n")
cat("Total rows in final (after PCS expansion):", nrow(final), "\n")
View(final)
