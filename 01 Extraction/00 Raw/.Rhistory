# standardize, and save as data_clean/personnel_firmX.rda.
#
# Output: one .rda file per firm containing a data frame named `df`.
#
# What is included per firm:
#   A — personnel YYYY.xlsx (2019–2023): worker × month panel; year from filename
#   B — personnel all.xlsx: cross-sectional; termination embedded (quitdate col)
#   C — personnel all.xlsx: worker × year panel; year col already in data
#   D — personnel all.xlsx: worker × year panel; no line variable
#   E — personnel YYYY.xlsx + termination YYYY.xlsx: stacked; record_type col added
#   F — personnel all.xlsx: cross-sectional; line mostly null
#   G — personnel YYYY.xlsx: worker × year panel; year from filename
#   H — personnel all.xlsx + termination YYYY.xlsx: stacked; record_type col added
#   I — YYYY.xlsx (no prefix): worker × year panel; year from filename
# II. CONFIGURATION ----
library(readxl)
library(dplyr)
library(lubridate)
library(writexl)
user <- Sys.info()[["user"]]
sys  <- Sys.info()[["nodename"]]
if (user == "Florian_Perso" & sys == "DESKTOP-S6DPM01"){
work_folder <- "C:/Users/Florian_Perso/Dropbox/Research/13_Ethiopia/HIP_Industrialization_Networks/"
} else if (user == "grossetflorian" & sys == "DESKTOP-S6DPM01") {
work_folder <- "C:/Users/grossetflorian/Dropbox/Research/13_Ethiopia/HIP_Industrialization_Networks/"
} else if (user == "fgrosset" & sys == "PC29SJ2J2") {
work_folder <- "C:/Users/fgrosset/Dropbox/Research/13_Ethiopia/HIP_Industrialization_Networks/"
} else if(user == "maria" & sys == "MacBook-Pro-71.local"){
work_folder <- "/Users/maria/Desktop/RA/01 Ethiopia/admin_data/"
} else {
stop("Unknown user/system. Please update the path configuration in the script.")
}
input_folder  <- file.path(work_folder, "04_Data_sharable/01_data/02_firm")
output_folder <- file.path(work_folder, "04_Data_sharable/04_data_clean")
dir.create(output_folder, showWarnings = FALSE)
year_from_filename <- function(path) {
m <- regmatches(basename(path), regexpr("\\d{4}", basename(path)))
if (length(m) == 0) return(NA_integer_)
as.integer(m)
}
read_files <- function(subfolder, pattern, add_year = FALSE,
record_type = NULL, col_types = NULL) {
folder <- file.path(input_folder, subfolder)
files  <- list.files(folder, pattern = pattern,
full.names = TRUE, ignore.case = TRUE)
if (length(files) == 0) {
message("  No files matched '", pattern, "' in subfolder ", subfolder)
return(NULL)
}
dfs <- lapply(files, function(f) {
sheets    <- excel_sheets(f)
sheet_dfs <- lapply(sheets, function(sheet) {
df <- tryCatch(
suppressWarnings(read_excel(f, sheet = sheet, col_types = col_types)),
error = function(e) {
message("  Could not read: ", basename(f),
" (sheet: ", sheet, ") — ", conditionMessage(e))
NULL
}
)
if (!is.null(df)) {
if (add_year && !"year" %in% names(df))
df[["year"]] <- year_from_filename(f)
if (!is.null(record_type))
df[["record_type"]] <- record_type
}
df
})
bind_rows(Filter(Negate(is.null), sheet_dfs))
})
bind_rows(Filter(Negate(is.null), dfs))
}
# Trim whitespace from all character columns
trim_strings <- function(df) {
df |> mutate(across(where(is.character), trimws))
}
save_firm <- function(df, firm) {
path <- file.path(output_folder, paste0("personnel_firm", firm, ".rda"))
save(df, file = path)
message("  Saved personnel_firm", firm, ".rda  (",
nrow(df), " rows, ", ncol(df), " cols)")
}
# Help to parse hireddate columns. In firm A, they mix four formats across years:
#   1. Text that looks from Stata "17jul2016".
#   2. Slash-delimited "17/07/2016".
#   3. Stata date serial: "20652". These are Stata serials, thus start from 1960-01-01,
#.     and not Excel serials (start from 1899-12-30). 20652 → 2016-07-17 makes sense.
#   4. ISO string "YYYY-MM-DD": produced when readxl reads a cell that is
#      Excel-date-formatted (returns POSIXct) and we call as.character().
#      NB If you do not use lubridate order "Ymd" then those strings silently
#      become NA.
#   5. Missing / zero: "", "0", NA → NA
parse_hireddate <- function(x) {
dplyr::case_when(
is.na(x) | trimws(x) == "" | trimws(x) == "0"
~ as.Date(NA),
# 5-digit all-numeric string: Stata date serial (origin 1960-01-01)
grepl("^\\d{5}$", trimws(x))
~ as.Date(as.numeric(trimws(x)), origin = "1960-01-01"),
# Text formats: ISO (Ymd), Stata-style (dby), slash-delimited (dmy / dmY)
TRUE
~ as.Date(suppressWarnings(
parse_date_time(trimws(x), orders = c("Ymd", "dby", "dmy", "dmY"), quiet = TRUE)
))
)
}
message("\nFirm A: personnel data ===")
df_pers <- read_files("a", "^personnel.*\\.xlsx$", add_year = TRUE, col_types = "text")
# import comments and missing hireddates
message("Rows read: ", nrow(df_pers),
"  |  Distinct years: ",
paste(sort(unique(df_pers$year)), collapse = ", "),
"  |  Missing hireddate (raw): ", sum(is.na(df_pers$hireddate)),
"  (expected: 7772 = 1617 from 2019 + 6155 from 2023)")
# type coercion
df_pers <- df_pers %>%
trim_strings() %>%
mutate(
year      = as.integer(year),
month     = suppressWarnings(as.integer(month)),
hireddate = parse_hireddate(as.character(hireddate))) %>%
arrange(randomid, year, month)
n_hireddate_na <- sum(is.na(df_pers$hireddate))
message("hireddate: ", nrow(df_pers) - n_hireddate_na,
" parsed; ", n_hireddate_na, " remain NA.")
# check for duplicates
message("\nChecking uniqueness at worker-month-year level...")
duplicates_pers <- df_pers %>%
count(randomid, year, month) %>%
filter(n > 1)
if (nrow(duplicates_pers) > 0) {
message("Warning: The data for Firm A is not uniquely identified at the worker-month-year level.")
print(duplicates)
} else {
message("Sanity check passed: personnel data for firm A is unique at worker-month-year level.")
